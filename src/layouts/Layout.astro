---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
}
const { title, description, ogImage } = Astro.props;
const siteUrl = 'https://telezhky.kz';
const ogUrl = ogImage ? new URL(ogImage, Astro.site).href : `${siteUrl}/favicon.svg`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogUrl} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #08090a;
      --bg-panel: #0f1011;
      --bg-surface: #191a1b;
      --bg-card: rgba(255,255,255,0.02);
      --bg-card-hover: rgba(255,255,255,0.04);
      --border: rgba(255,255,255,0.08);
      --border-subtle: rgba(255,255,255,0.05);
      --text: #f7f8f8;
      --text-secondary: #d0d6e0;
      --text-tertiary: #8a8f98;
      --text-muted: #62666d;
      --accent: #f0883e;
      --accent-hover: #ff9a4d;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text-secondary);
      line-height: 1.6;
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
    }

    /* —— View Transitions —— */
    @view-transition { navigation: auto; }

    /* —— Typography —— */
    h1, h2, h3 { color: var(--text); font-weight: 600; }
    h1 { font-size: 3rem; line-height: 1.1; letter-spacing: -0.03em; }
    h2 { font-size: 2rem; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 2.5rem; text-align: center; }
    h3 { font-size: 1.25rem; line-height: 1.3; letter-spacing: -0.01em; margin-bottom: 0.5rem; }
    p { color: var(--text-tertiary); }
    a { color: inherit; text-decoration: none; }

    /* —— Layout —— */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

    /* —— Header —— */
    header {
      position: sticky; top: 0; z-index: 10;
      background: var(--bg-panel);
      border-bottom: 1px solid var(--border-subtle);
      backdrop-filter: blur(12px);
    }
    header .container { display: flex; justify-content: space-between; align-items: center; padding-top: 0.75rem; padding-bottom: 0.75rem; }
    header .logo { font-size: 1rem; font-weight: 600; color: var(--text); letter-spacing: -0.01em; }
    nav { display: flex; gap: 1.5rem; }
    nav a { font-size: 0.875rem; font-weight: 500; color: var(--text-tertiary); transition: color 0.15s; }
    nav a:hover { color: var(--text); }

    /* —— Mobile Nav —— */
    .menu-toggle { display: none; background: none; border: none; cursor: pointer; padding: 0.25rem; }
    .menu-toggle span { display: block; width: 20px; height: 2px; background: var(--text); margin: 5px 0; border-radius: 2px; transition: transform 0.2s, opacity 0.2s; }
    .menu-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .menu-toggle.open span:nth-child(2) { opacity: 0; }
    .menu-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    nav.mobile-open { display: flex !important; }

    /* —— Hero —— */
    .hero { text-align: center; padding: 7rem 0 5rem; animation: fadeUp 0.6s ease-out; }
    .hero h1 { font-size: 3.5rem; line-height: 1.05; letter-spacing: -0.035em; max-width: 800px; margin: 0 auto 1.25rem; }
    .hero p { font-size: 1.125rem; color: var(--text-tertiary); max-width: 560px; margin: 0 auto 2rem; line-height: 1.7; }

    /* —— Animations —— */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .reveal { animation: fadeUp 0.5s ease-out both; }
    .reveal:nth-child(1) { animation-delay: 0.1s; }
    .reveal:nth-child(2) { animation-delay: 0.2s; }
    .reveal:nth-child(3) { animation-delay: 0.3s; }
    .reveal:nth-child(4) { animation-delay: 0.4s; }
    .reveal:nth-child(5) { animation-delay: 0.5s; }
    .reveal:nth-child(6) { animation-delay: 0.6s; }

    /* —— Buttons —— */
    .btn-group { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 0.875rem; font-weight: 500;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      cursor: pointer; border: 1px solid transparent;
      transition: all 0.15s ease;
      text-decoration: none;
    }
    .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
    .btn-primary:hover { background: var(--accent-hover); border-color: var(--accent-hover); color: #fff; transform: scale(1.02); }
    .btn-ghost { background: rgba(255,255,255,0.02); color: var(--text-secondary); border-color: var(--border); }
    .btn-ghost:hover { background: rgba(255,255,255,0.05); color: var(--text); border-color: rgba(255,255,255,0.12); }

    /* —— Section —— */
    section { padding: 5rem 0; }

    /* —— Grid & Cards —— */
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1rem; }
    .card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 8px; padding: 1.5rem;
      transition: background 0.2s, border-color 0.2s, transform 0.2s;
    }
    .card:hover { background: var(--bg-card-hover); border-color: var(--accent); transform: translateY(-2px); }
    .card p { font-size: 0.938rem; line-height: 1.6; }
    .features .card { text-align: center; }
    .features .icon { font-size: 1.5rem; margin-bottom: 0.75rem; display: block; }

    /* —— Tag —— */
    .tag {
      display: inline-block; font-size: 0.688rem; font-weight: 500;
      padding: 0.125rem 0.5rem; border-radius: 9999px;
      background: rgba(255,255,255,0.05); color: var(--text-tertiary);
      border: 1px solid var(--border-subtle);
      margin-top: 0.75rem;
    }

    /* —— FAQ (details) —— */
    details {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 8px; margin-bottom: 0.5rem;
      transition: border-color 0.2s;
    }
    details[open] { border-color: var(--accent); }
    details summary { padding: 1rem 1.5rem; cursor: pointer; font-weight: 500; color: var(--text); font-size: 0.938rem; user-select: none; }
    details summary::marker { color: var(--text-muted); }
    details p { padding: 0 1.5rem 1.25rem; font-size: 0.875rem; animation: fadeIn 0.3s ease; }

    /* —— Footer —— */
    footer {
      border-top: 1px solid var(--border-subtle);
      padding: 3rem 0; text-align: center;
      font-size: 0.813rem; color: var(--text-muted);
    }
    footer a { color: var(--text-tertiary); transition: color 0.15s; }
    footer a:hover { color: var(--text); }
    footer p + p { margin-top: 0.5rem; }

    /* —— Separator —— */
    hr { border: none; border-top: 1px solid var(--border-subtle); margin: 2rem 0; }

    /* —— Responsive —— */
    @media (max-width: 768px) {
      .hero { padding: 4rem 0 3rem; }
      .hero h1 { font-size: 2.25rem; letter-spacing: -0.02em; }
      .hero p { font-size: 1rem; }
      h1 { font-size: 2rem; }
      h2 { font-size: 1.5rem; margin-bottom: 1.5rem; }
      section { padding: 3rem 0; }
      .container { padding: 0 1.25rem; }
      nav { display: none; flex-direction: column; gap: 0.5rem; position: absolute; top: 100%; left: 0; right: 0; background: var(--bg-panel); border-bottom: 1px solid var(--border-subtle); padding: 1rem 1.25rem; backdrop-filter: blur(12px); }
      nav a { padding: 0.5rem 0; }
      .menu-toggle { display: block; }
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <a href="/" class="logo">Тележки.kz</a>
      <button class="menu-toggle" id="menuToggle" aria-label="Меню">
        <span></span><span></span><span></span>
      </button>
      <nav id="mainNav">
        <a href="/catalog">Каталог</a>
        <a href="/about">О нас</a>
        <a href="/contacts">Контакты</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <div class="container">
      <p>© 2026 Тележки.kz — тележки для склада, магазина и производства.</p>
      <p><a href="tel:+770****7707">+7 707 658-77-07</a> · <a href="mailto:qazmediagroupcompany@gmail.com">qazmediagroupcompany@gmail.com</a></p>
      <p><a href="/policy">Политика конфиденциальности</a></p>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menuToggle');
    const nav = document.getElementById('mainNav');
    toggle.addEventListener('click', () => {
      toggle.classList.toggle('open');
      nav.classList.toggle('mobile-open');
    });
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Тележки.kz",
    "description": "Производство и продажа тележек для склада, магазина и производства в Казахстане.",
    "url": "https://telezhky.kz",
    "telephone": "+77076587707",
    "email": "qazmediagroupcompany@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Алматы",
      "addressCountry": "KZ"
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "18:00"
    },
    "areaServed": {
      "@type": "Country",
      "name": "Казахстан"
    }
  }
  </script>
</body>
</html>
