{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Dark industrial minimalism inspired by Linear.app — precision, clarity, and one accent color.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.031,
          0.035,
          0.039
        ],
        "hex": "#08090a"
      }
    },
    "bg": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.031,
          0.035,
          0.039
        ],
        "hex": "#08090a"
      }
    },
    "bg-panel": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.063,
          0.067
        ],
        "hex": "#0f1011"
      }
    },
    "bg-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.098,
          0.102,
          0.106
        ],
        "hex": "#191a1b"
      }
    },
    "bg-card": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.051,
          0.055,
          0.059
        ],
        "hex": "#0d0e0f"
      }
    },
    "bg-card-hover": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.071,
          0.075,
          0.078
        ],
        "hex": "#121314"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.11,
          0.114,
          0.122
        ],
        "hex": "#1c1d1f"
      }
    },
    "border-subtle": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.078,
          0.082,
          0.086
        ],
        "hex": "#141516"
      }
    },
    "text": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.969,
          0.973,
          0.973
        ],
        "hex": "#f7f8f8"
      }
    },
    "text-secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.816,
          0.839,
          0.878
        ],
        "hex": "#d0d6e0"
      }
    },
    "text-tertiary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.541,
          0.561,
          0.596
        ],
        "hex": "#8a8f98"
      }
    },
    "text-muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.384,
          0.4,
          0.427
        ],
        "hex": "#62666d"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.941,
          0.533,
          0.243
        ],
        "hex": "#f0883e"
      }
    },
    "accent-hover": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.604,
          0.302
        ],
        "hex": "#ff9a4d"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 0.5,
        "unit": "rem"
      }
    },
    "sm": {
      "$value": {
        "value": 1,
        "unit": "rem"
      }
    },
    "md": {
      "$value": {
        "value": 1.5,
        "unit": "rem"
      }
    },
    "lg": {
      "$value": {
        "value": 2.5,
        "unit": "rem"
      }
    },
    "xl": {
      "$value": {
        "value": 5,
        "unit": "rem"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 3.5,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.035,
          "unit": "em"
        }
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 2,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "h3": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.25,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.01,
          "unit": "em"
        }
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-xs": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.813,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    }
  }
}
